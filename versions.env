# Shared version pins — sourced by scripts/setup-fluxcd-gitops-kind-multinode.sh
# and included by Makefile. Update here only; both consumers pick up the change.
#
# Keep in sync with the chart version constraints in infrastructure/controllers/:
#   cilium.yaml        → CILIUM_VERSION
#   istio.yaml         → ISTIO_VERSION
#   envoy-gateway.yaml → ENVOY_GATEWAY_VERSION
CILIUM_VERSION=1.19.5
ISTIO_VERSION=1.30.1
CONTOUR_VERSION=v1.33.5
K8S_VER=v1.36.1
CLUSTER_NAME=flux-kind
KUBESCAPE_VERSION=v4.0.9
